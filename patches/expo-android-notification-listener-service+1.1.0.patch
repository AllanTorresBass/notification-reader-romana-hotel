+
+private fun extractNotificationText(extras: android.os.Bundle): Triple<String, String, String> {
+    var title = charSequenceToString(extras.getCharSequence(Notification.EXTRA_TITLE))
+    var text = charSequenceToString(extras.getCharSequence(Notification.EXTRA_TEXT))
+    var bigText = charSequenceToString(extras.getCharSequence(Notification.EXTRA_BIG_TEXT))
+
+    if (title.isEmpty()) {
+        title = charSequenceToString(extras.getCharSequence("android.title"))
+    }
+    if (text.isEmpty()) {
+        text = charSequenceToString(extras.getCharSequence("android.text"))
+    }
+    if (bigText.isEmpty()) {
+        bigText = charSequenceToString(extras.getCharSequence("android.bigText"))
+    }
+
+    val lines = extras.getCharSequenceArray(Notification.EXTRA_TEXT_LINES)
+    if (lines != null && lines.isNotEmpty()) {
+        val joined = lines.joinToString(" ") { charSequenceToString(it) }.trim()
+        if (joined.isNotEmpty() && joined.length > bigText.length) {
+            bigText = joined
+        }
+    }
+
+    val messages = extras.getParcelableArray("android.messages")
+    if (messages != null && messages.isNotEmpty()) {
+        val messageText = messages.mapNotNull { parcel ->
+            (parcel as? android.os.Bundle)?.getCharSequence("text")?.toString()?.trim()
+        }.filter { it.isNotEmpty() }.joinToString(" ")
+        if (messageText.isNotEmpty() && messageText.length > bigText.length) {
+            bigText = messageText
+        }
+    }
+
+    if (text.isEmpty() && bigText.isNotEmpty()) {
+        text = bigText
+    }
+
+    return Triple(title, text, bigText)
+}
